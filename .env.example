# Retell AI Configuration (REQUIRED for auto-calling)
RETELL_API_KEY=your_retell_api_key
RETELL_FROM_NUMBER=+1XXXXXXXXXX
RETELL_AGENT_ID=agent_xxxxxxxxxxxxxxxxxxxxx

# SMTP Email Configuration (Agent emails: contact@duckbookwriters.com → user)
# IMPORTANT: Add these to Vercel Environment Variables for production
# Use mail. subdomain (main domain can timeout from Vercel)
SMTP_HOST=mail.duckbookwriters.com
SMTP_PORT=465
# If you get "Connection timeout" on Vercel, try SMTP_PORT=587 (STARTTLS)
SMTP_USER=contact@duckbookwriters.com
# Wrap in double quotes if password has special chars
SMTP_PASS=your_email_password

# Calendly — inline widget URL (optional; public). Use the full link: https://calendly.com/username/event-type
# If unset, app/config/constants.ts default is used site-wide.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/meeting-duckbookwriters/30min

# Calendly (REQUIRED for Calendly → call flow)
# Create at https://developer.calendly.com/ — Personal Access Token with user or organization scope
CALENDLY_API_TOKEN=your_calendly_personal_access_token

# Resend API Key (form notifications)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: who receives form notifications. On Resend free/test mode you can ONLY email your verified account address until you verify a domain at https://resend.com/domains — then use contact@yourdomain and set RESEND_FROM_EMAIL.
# RESEND_NOTIFICATION_TO=your-verified-email@gmail.com
# RESEND_FROM_EMAIL=onboarding@resend.dev

# Contact Email (configured in app/config/constants.ts)
# CONTACT_EMAIL=contact@duckbookwriters.com
